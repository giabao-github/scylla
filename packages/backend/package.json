{
  "name": "@workspace/backend",
  "type": "module",
  "scripts": {
    "dev": "cross-env CONVEX_TMPDIR=../../.convex-tmp convex dev",
    "setup": "cross-env CONVEX_TMPDIR=../../.convex-tmp convex dev --until-success"
  },
  "exports": {
    "./convex/*": "./convex/*.ts",
    "./_generated/*": {
      "types": "./convex/_generated/*.d.ts",
      "default": "./convex/_generated/*.js"
    }
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.2.3",
    "@workspace/typescript-config": "workspace:*",
    "cross-env": "^10.1.0",
    "typescript": "latest"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.61",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@aws-sdk/client-secrets-manager": "^3.1029.0",
    "@clerk/backend": "^3.0.1",
    "@clerk/nextjs": "^6.37.3",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/agent-playground": "^0.0.20",
    "@convex-dev/rag": "^0.7.2",
    "@workspace/shared": "workspace:*",
    "@workspace/ui": "workspace:*",
    "ai": "^6.0.158",
    "convex": "^1.34.0",
    "convex-helpers": "^0.1.114",
    "svix": "^1.89.0",
    "zod": "^4.3.6"
  }
}
